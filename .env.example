# Runtime
DATABASE_URL=postgres://juno_wholesale_ops_app:change-me@localhost:5432/juno_wholesale_ops?sslmode=disable

# DSUB SSO / admin gate
# Unset locally means auth is enabled only when NODE_ENV=production.
DSUB_AUTH_ENABLED=false
DSUB_KRATOS_PUBLIC_URL=https://auth.dsub.io
DSUB_LOGIN_URL=https://www.dsub.io/auth/login
DSUB_LOGIN_REDIRECT_PARAM=redirect
DSUB_REQUIRED_ROLE=admin
DSUB_SESSION_COOKIE_NAMES=dsub_session,dsub_session_dev

# Production deployment defaults
JUNO_WHOLESALE_OPS_WEB_IMAGE=harbor.dsub.io/dsub/juno-wholesale-ops-web:sha-REPLACE_ME
JUNO_WHOLESALE_OPS_WEB_PUBLIC_PORT=3100

# Gmail ingestion
GOOGLE_WORKSPACE_DELEGATED_USER=state303@dsub.io
GOOGLE_SERVICE_ACCOUNT_KEY_JSON=/run/secrets/juno-mail-service-account.json
GOOGLE_GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.modify
GMAIL_INGEST_QUERY=to:inventory@dsub.io has:attachment filename:xlsx newer_than:30d
GMAIL_MAX_RESULTS=25
GMAIL_INGEST_LOOKBACK_MS=604800000
GMAIL_PROCESSED_LABEL=Wholesale Processed
GMAIL_STORAGE_DIR=.data/mail-attachments
CATALOG_ATTACHMENT_PATTERN=New Preorders|New Releases In Stock

# Catalog defaults
SUPPLIER_CODE=juno

# Juno live stock worker
JUNO_LIVE_ENQUEUE_ON_INGEST=false
JUNO_LOGIN_EMAIL=
JUNO_LOGIN_PASSWORD=
JUNO_BROWSER_PROFILE_DIR=.data/juno-browser-profile
JUNO_BROWSER_HEADLESS=true
JUNO_LIVE_CONCURRENCY=6
JUNO_LIVE_DELAY_MIN_MS=15000
JUNO_LIVE_DELAY_MAX_MS=75000
JUNO_LIVE_NAV_TIMEOUT_MS=45000
JUNO_LIVE_MAX_ATTEMPTS=2
JUNO_LIVE_POLL_INTERVAL_MS=
JUNO_LIVE_AUTO_ENQUEUE_ON_INTERVAL=true
JUNO_LIVE_AUTO_ENQUEUE_LIMIT=1000
JUNO_LIVE_WORKER_COMMAND=
JUNO_LIVE_WORKER_ARGS=
