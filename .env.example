# Runtime
DATABASE_URL=postgres://juno_wholesale_ops_app:change-me@localhost:5437/juno_wholesale_ops?sslmode=disable
JUNO_WHOLESALE_OPS_DATA_MODE=demo

# Admin authentication
# Optional runtime override. If blank, startup generates and stores an internal
# Better Auth secret in Postgres; Settings Center never displays or edits it.
AUTH_SECRET=
# Bootstrap fallback only. The Settings Center "Site address" database setting
# wins once saved and owns Better Auth callback URL generation.
AUTH_BASE_URL=
AUTH_TRUSTED_ORIGINS=
JUNO_WHOLESALE_OPS_AUTH_PROXY_INTERNAL_ORIGIN=
AUTH_EMAIL_PASSWORD_ENABLED=true
AUTH_EXTERNAL_PROVIDER_ENABLED=false
AUTH_EXTERNAL_PROVIDER_ID=
AUTH_EXTERNAL_PROVIDER_NAME=
AUTH_EXTERNAL_PROVIDER_LOGO_URL=
AUTH_EXTERNAL_PROVIDER_BUTTON_LABEL=
AUTH_EXTERNAL_DISCOVERY_URL=
AUTH_EXTERNAL_CLIENT_ID=
AUTH_EXTERNAL_CLIENT_SECRET=
AUTH_EXTERNAL_PROVIDER_SCOPES=openid email profile
AUTH_ADMIN_EMAIL_ALLOWLIST=
AUTH_EXTERNAL_ADMIN_CLAIM=
AUTH_EXTERNAL_ADMIN_CLAIM_VALUE=
AUTH_INITIAL_ADMIN_EMAIL=
AUTH_INITIAL_ADMIN_PASSWORD=
AUTH_INITIAL_ADMIN_NAME=Initial Admin
NEXT_PUBLIC_FONT_STYLESHEET_URL=

# Production deployment defaults
JUNO_WHOLESALE_OPS_WEB_IMAGE=registry.example.com/example/juno-wholesale-ops-web:sha-REPLACE_ME
JUNO_WHOLESALE_OPS_WEB_PUBLIC_PORT=3006

# Optional local Cloudflare Tunnel for exposing the dev server.
# Copy infra/cloudflared/dev.template.yml to .data/cloudflared/config.yml and
# keep the tunnel credentials in .data/cloudflared/credentials.json.
JUNO_WHOLESALE_OPS_CLOUDFLARED_IMAGE=cloudflare/cloudflared:2026.3.0
JUNO_WHOLESALE_OPS_CLOUDFLARED_CONTAINER_NAME=juno-wholesale-ops-cloudflared
JUNO_WHOLESALE_OPS_CLOUDFLARED_CONFIG=../.data/cloudflared/config.yml
JUNO_WHOLESALE_OPS_CLOUDFLARED_CREDENTIALS=../.data/cloudflared/credentials.json
JUNO_WHOLESALE_OPS_DEV_ALLOWED_ORIGINS=

# Gmail ingestion
GOOGLE_WORKSPACE_DELEGATED_USER=
GOOGLE_SERVICE_ACCOUNT_KEY_JSON=
GOOGLE_GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.readonly
GMAIL_INGEST_QUERY=has:attachment filename:xlsx newer_than:30d
GMAIL_MAX_RESULTS=25
GMAIL_INGEST_LOOKBACK_MS=604800000
GMAIL_PROCESSED_LABEL=Wholesale Processed
GMAIL_STORAGE_DIR=.data/mail-attachments
CATALOG_ATTACHMENT_PATTERN=New Preorders|New Releases In Stock

# Catalog defaults
SUPPLIER_CODE=juno

# Juno live stock worker
JUNO_LIVE_ENQUEUE_ON_INGEST=false
JUNO_LOGIN_EMAIL=
JUNO_LOGIN_PASSWORD=
JUNO_BROWSER_PROFILE_DIR=.data/juno-browser-profile
JUNO_BROWSER_HEADLESS=true
JUNO_LIVE_CONCURRENCY=1
JUNO_LIVE_DELAY_MIN_MS=30000
JUNO_LIVE_DELAY_MAX_MS=180000
JUNO_LIVE_NAV_TIMEOUT_MS=45000
JUNO_LIVE_MAX_ATTEMPTS=2
JUNO_LIVE_POLL_INTERVAL_MS=
JUNO_LIVE_AUTO_ENQUEUE_ON_INTERVAL=false
JUNO_LIVE_AUTO_ENQUEUE_LIMIT=1000
JUNO_LIVE_WORKER_COMMAND=
JUNO_LIVE_WORKER_ARGS=
