{
  "name": "juno-wholesale-ops",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "validate": "pnpm lint && pnpm typecheck && pnpm db:migrations:check && pnpm test:coverage && pnpm unused",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "unused": "knip --reporter symbols",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "storybook": "storybook dev -p 6008",
    "build-storybook": "storybook build",
    "db:migrate": "tsx -r tsconfig-paths/register scripts/db-migrate.ts",
    "db:migrations:check": "tsx -r tsconfig-paths/register scripts/db-migrations-check.ts",
    "db:schema:dump": "tsx -r tsconfig-paths/register scripts/db-schema-dump.ts",
    "gmail:smoke": "tsx -r tsconfig-paths/register scripts/gmail-smoke.ts",
    "gmail:ingest": "tsx -r tsconfig-paths/register scripts/gmail-ingest.ts",
    "gmail:ingest:write": "tsx -r tsconfig-paths/register scripts/gmail-ingest.ts --write",
    "juno:live:enqueue": "tsx -r tsconfig-paths/register scripts/juno-live-enqueue.ts",
    "juno:live:worker": "tsx -r tsconfig-paths/register scripts/juno-live-worker.ts"
  },
  "dependencies": {
    "@mantine/core": "^9.3.2",
    "@mantine/hooks": "^9.3.2",
    "@t3-oss/env-nextjs": "^0.13.11",
    "lucide-react": "^1.20.0",
    "next": "16.2.9",
    "pg": "^8.21.0",
    "playwright": "1.61.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "xlsx": "^0.18.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/nextjs-vite": "^10.4.6",
    "@testcontainers/postgresql": "^12.0.2",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.1.1",
    "knip": "^6.17.1",
    "storybook": "^10.4.6",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
