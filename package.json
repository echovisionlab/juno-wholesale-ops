{
  "name": "juno-wholesale-ops",
  "version": "0.3.1",
  "private": true,
  "packageManager": "pnpm@10.34.1",
  "scripts": {
    "dev": "next dev -p 3006",
    "build": "next build",
    "start": "next start -p 3006",
    "validate": "pnpm lint && pnpm typecheck && pnpm db:migrations:check && pnpm public:safety && pnpm test:coverage && pnpm unused",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "unused": "knip --reporter symbols",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "storybook": "storybook dev -p 6008",
    "build-storybook": "storybook build",
    "db:dev:volume": "docker volume inspect juno-wholesale-ops-postgres-data >/dev/null 2>&1 || docker volume create juno-wholesale-ops-postgres-data >/dev/null",
    "db:dev:up": "pnpm db:dev:volume && docker compose -f compose/dev.yml up -d postgres",
    "db:dev:down": "docker compose -f compose/dev.yml down",
    "db:dev:logs": "docker compose -f compose/dev.yml logs -f postgres",
    "db:dev:status": "docker compose -f compose/dev.yml ps postgres",
    "storage:dev:volume": "docker volume inspect juno-wholesale-ops-minio-data >/dev/null 2>&1 || docker volume create juno-wholesale-ops-minio-data >/dev/null",
    "storage:dev:up": "pnpm storage:dev:volume && docker compose -f compose/dev.yml up -d minio minio-init",
    "storage:dev:down": "docker compose -f compose/dev.yml stop minio minio-init",
    "storage:dev:logs": "docker compose -f compose/dev.yml logs -f minio minio-init",
    "storage:dev:status": "docker compose -f compose/dev.yml ps minio minio-init",
    "tunnel:dev:up": "docker compose -f compose/dev.yml up -d cloudflared",
    "tunnel:dev:down": "docker compose -f compose/dev.yml stop cloudflared",
    "tunnel:dev:logs": "docker compose -f compose/dev.yml logs -f cloudflared",
    "tunnel:dev:status": "docker compose -f compose/dev.yml ps cloudflared",
    "db:migrate": "tsx -r tsconfig-paths/register scripts/db-migrate.ts",
    "db:migrations:check": "tsx -r tsconfig-paths/register scripts/db-migrations-check.ts",
    "db:schema:dump": "tsx -r tsconfig-paths/register scripts/db-schema-dump.ts",
    "gmail:smoke": "tsx -r tsconfig-paths/register scripts/gmail-smoke.ts",
    "gmail:ingest": "tsx -r tsconfig-paths/register scripts/gmail-ingest.ts",
    "gmail:ingest:write": "tsx -r tsconfig-paths/register scripts/gmail-ingest.ts --write",
    "juno:live:enqueue": "tsx -r tsconfig-paths/register scripts/juno-live-enqueue.ts",
    "juno:live:worker": "tsx -r tsconfig-paths/register scripts/juno-live-worker.ts",
    "insights:movement": "tsx -r tsconfig-paths/register scripts/insights-movement.ts",
    "insights:trends": "tsx -r tsconfig-paths/register scripts/insights-trends.ts",
    "insights:refresh": "tsx -r tsconfig-paths/register scripts/insights-refresh.ts",
    "notifications:queue": "tsx -r tsconfig-paths/register scripts/notifications-queue.ts",
    "notifications:dispatch": "tsx -r tsconfig-paths/register scripts/notifications-dispatch.ts",
    "notifications:refresh": "tsx -r tsconfig-paths/register scripts/notifications-refresh.ts",
    "demo:seed": "tsx -r tsconfig-paths/register scripts/demo-seed.ts",
    "demo:reset": "tsx -r tsconfig-paths/register scripts/demo-reset.ts",
    "public:safety": "tsx -r tsconfig-paths/register scripts/check-public-safety.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1072.0",
    "@mantine/core": "^9.3.2",
    "@mantine/hooks": "^9.3.2",
    "@mantine/notifications": "^9.3.2",
    "@t3-oss/env-nextjs": "^0.13.11",
    "better-auth": "1.6.19",
    "kysely": "^0.29.2",
    "lucide-react": "^1.20.0",
    "next": "16.2.9",
    "pg": "^8.21.0",
    "playwright": "1.61.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "read-excel-file": "^9.2.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/nextjs-vite": "^10.4.6",
    "@testcontainers/postgresql": "^12.0.2",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "jsdom": "^29.1.1",
    "knip": "^6.17.1",
    "storybook": "^10.4.6",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9",
    "write-excel-file": "^4.1.1"
  },
  "pnpm": {
    "overrides": {
      "postcss": "8.5.15"
    }
  }
}
